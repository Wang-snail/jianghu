# Copy this file to .env on the server next to docker-compose.public.yml.
# Do not commit the real .env file.

# Public hostname that points to the server, for example jianghu.example.com.
PUBLIC_DOMAIN=jianghu.example.com
ACME_EMAIL=you@example.com

# Must exactly match the public browser origin.
COMPANY_ALLOWED_ORIGINS=https://jianghu.example.com

# Stable random id for this deployment. Keep it unchanged after first launch.
COMPANY_CLOUD_INSTANCE_ID=jianghu-prod-001

# Generate both secrets with:
#   openssl rand -hex 32
COMPANY_SECRET_KEY=replace-with-64-hex-secret
COMPANY_CLOUD_JWT_SECRET=replace-with-64-hex-secret

# Optional model/API credentials. Prefer setting them in the UI after deployment
# unless you intentionally want container-level credentials.
MIMO_API_KEY=
MIMO_BASE_URL=https://nexus.itssx.com/api/openai/v1
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
GEMINI_API_KEY=
JIANGHU_TELEGRAM_BOT_TOKEN=
