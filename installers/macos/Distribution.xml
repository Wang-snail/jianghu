<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>江湖</title>
    <organization>ai.jianghu</organization>
    <domains enable_localSystem="true" />
    <options customize="never" require-scripts="false" hostArchitectures="x86_64,arm64" />

    <welcome file="welcome.html" />
    <license file="license.html" />

    <choices-outline>
        <line choice="default">
            <line choice="ai.jianghu.cli" />
        </line>
    </choices-outline>

    <choice id="default" />
    <choice id="ai.jianghu.cli"
            visible="false"
            title="江湖"
            description="江湖本地运行工具">
        <pkg-ref id="ai.jianghu.cli" />
    </choice>

    <pkg-ref id="ai.jianghu.cli"
             version="0"
             onConclusion="none">zuzu-component.pkg</pkg-ref>
</installer-gui-script>
